APP_NAME=google-calendar-bot
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
APP_SKIP_EXTERNAL_CHECKS=false
APP_RUN_MIGRATIONS_ON_START=true
MAX_ACTIVE_REQUESTS_PER_USER=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_INVITE_TOKEN=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_DROP_PENDING_UPDATES_ON_START=false
TELEGRAM_ADMIN_ID=

BACKGROUND_JOBS_ENABLED=true
BACKGROUND_RESERVATION_CHECK_INTERVAL_SECONDS=60
BACKGROUND_REMINDERS_CHECK_INTERVAL_SECONDS=60
BACKGROUND_TECHNICAL_CHECK_INTERVAL_SECONDS=120
BACKGROUND_ADMIN_REMINDER_AFTER_HOURS=12
BACKGROUND_MEETING_REMINDER_BEFORE_MINUTES=120
BACKGROUND_NOTIFICATION_RETRY_DELAY_SECONDS=60
BACKGROUND_NOTIFICATION_MAX_ATTEMPTS=3
BACKGROUND_TECHNICAL_ERRORS_LOOKBACK_HOURS=48

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar

MINIAPP_ENABLED=true
MINIAPP_DEV_LOGIN_ENABLED=true
MINIAPP_SESSION_TTL_MINUTES=120
MINIAPP_AUTH_MAX_AGE_SECONDS=3600

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=calendar_bot
POSTGRES_USER=calendar_user
POSTGRES_PASSWORD=calendar_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
